msgid "Block Email Domains"
msgstr "Blokkeer e-maildomeinen"

msgid "Import blocked domains from file"
msgstr "Geïmporteerde geblokkeerde domeinen uit bestand"

msgid "Select a plain text file containing one domain per line. Importing will add valid domains to the blocked list; duplicates are ignored."
msgstr "Selecteer een platte tekstbestand met één domein per regel. Importeren voegt geldige domeinen toe aan de geblokkeerde lijst; duplicaten worden genegeerd."

msgid "Upload and Preview"
msgstr "Uploaden en Voorbeeld"

msgid "Import Summary — confirm to overwrite existing blocked domains"
msgstr "Importoverzicht — bevestig om bestaande geblokkeerde domeinen te overschrijven"

msgid "Existing domains will be fully replaced by the contents of the uploaded file. Review the summary below and confirm to proceed."
msgstr "Bestaande domeinen zullen volledig worden vervangen door de inhoud van het geüploade bestand. Controleer het overzicht hieronder en bevestig om door te gaan."

msgid "Start Import"
msgstr "Start import"

msgid "Cancel"
msgstr "Annuleren"

msgid "Total lines in file:"
msgstr "Totaal aantal regels in bestand:"

msgid "Unique domains found in file:"
msgstr "Unieke domeinen gevonden in bestand:"

msgid "Duplicates compared to configured blocked domains:"
msgstr "Duplicaten vergeleken met geconfigureerde geblokkeerde domeinen:"

msgid "Invalid lines:"
msgstr "Ongeldige regels:"

msgid "Manage blocked domains"
msgstr "Beheer geblokkeerde domeinen"

msgid "Search domains"
msgstr "Zoek domeinen"

msgid "Page size:"
msgstr "Pagina grootte:"

msgid "Add new blocked domain:"
msgstr "Nieuw geblokkeerd domein toevoegen:"

msgid "Add"
msgstr "Toevoegen"

msgid "Domain"
msgstr "Domein"

msgid "Actions"
msgstr "Acties"

msgid "Delete"
msgstr "Verwijderen"

msgid "Delete selected"
msgstr "Geselecteerde verwijderen"

msgid "Select all matching results across pages"
msgstr "Selecteer alle overeenkomende resultaten over pagina's"

msgid "Export visible/filtered list (CSV)"
msgstr "Exporteer zichtbare/gefiterde lijst (CSV)"

msgid "Delete selected domain(s)? This cannot be undone."
msgstr "Geselecteerde domein(en) verwijderen? Dit kan niet ongedaan worden gemaakt."

msgid "Enter a domain to add"
msgstr "Voer een domein in om toe te voegen"

msgid "Invalid domain"
msgstr "Ongeldig domein"

msgid "Add failed"
msgstr "Toevoegen mislukt"

msgid "Request failed"
msgstr "Verzoek mislukt"

msgid "Delete failed"
msgstr "Verwijderen mislukt"

msgid "Deleted %d domains."
msgstr "%d domeinen verwijderd."

msgid "Domain added: %s"
msgstr "Domein toegevoegd: %s"

msgid "Domain updated"
msgstr "Domein bijgewerkt"

msgid "Empty domain not allowed"
msgstr "Leeg domein niet toegestaan"

msgid "Restore failed"
msgstr "Herstellen mislukt"

msgid "Restored %d domains."
msgstr "%d domeinen hersteld."

msgid "Registration using this email domain is not allowed."
msgstr "Registratie met dit e-maildomein is niet toegestaan."
